<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ScreenSplitter.UI.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <SolidColorBrush x:Key="BgPanel" Color="#14181F" />
    <SolidColorBrush x:Key="BgPanelAlt" Color="#1B212B" />
    <SolidColorBrush x:Key="BgPanelSunken" Color="#0E1116" />
    <SolidColorBrush x:Key="LineHairline" Color="#2A3140" />
    <SolidColorBrush x:Key="AccentSignal" Color="#4FD1C5" />
    <SolidColorBrush x:Key="AccentAssigned" Color="#F2A65A" />
    <SolidColorBrush x:Key="AccentFree" Color="#7EE081" />
    <SolidColorBrush x:Key="AccentDanger" Color="#FF5D5D" />
    <SolidColorBrush x:Key="TextPrimary" Color="#E7ECF3" />
    <SolidColorBrush x:Key="TextMuted" Color="#8892A4" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <Style Selector="Button.action">
      <Setter Property="Background" Value="{StaticResource BgPanelAlt}" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="FontFamily" Value="Inter" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{StaticResource LineHairline}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.action:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AccentSignal}" />
      <Setter Property="TextBlock.Foreground" Value="#0B0E14" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentSignal}" />
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource AccentSignal}" />
      <Setter Property="Foreground" Value="#0B0E14" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="FontFamily" Value="Inter" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.88" />
    </Style>
  </Application.Styles>

  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/icon.ico" ToolTipText="ScreenSplitter">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Показать/скрыть меню" Click="OnToggleOverlay" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Разбить экран">
              <NativeMenuItem.Menu>
                <NativeMenu>
                  <NativeMenuItem Header="1 большой экран" Click="OnPatternSingleClicked" />
                  <NativeMenuItem Header="2 экрана: слева / справа" Click="OnPatternVerticalClicked" />
                  <NativeMenuItem Header="2 экрана: сверху / снизу" Click="OnPatternHorizontalClicked" />
                  <NativeMenuItem Header="4 экрана (сетка 2x2)" Click="OnPatternGrid2x2Clicked" />
                  <NativeMenuItemSeparator />
                  <NativeMenuItem Header="Свой вариант..." Click="OnPatternCustomClicked" />
                </NativeMenu>
              </NativeMenuItem.Menu>
            </NativeMenuItem>
            <NativeMenuItem Header="Сценарии..." Click="OnScenariosMenuClicked" />
            <NativeMenuItem Header="Настройки..." Click="OnSettingsMenuClicked" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Выход" Click="OnExit" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>

</Application>