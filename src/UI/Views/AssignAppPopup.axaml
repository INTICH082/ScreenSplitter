<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ScreenSplitter.UI.Views.AssignAppPopup"
        Width="220" Height="120"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        WindowStartupLocation="Manual">

  <Border Background="#EE1E1E1E"
          CornerRadius="10"
          Padding="12"
          BoxShadow="0 2 8 0 #40000000">
    <StackPanel Spacing="8">
      <TextBlock Text="Что разместить в этой зоне?"
                 Foreground="White"
                 FontSize="12"
                 TextWrapping="Wrap" />
      <Button Content="Свободный доступ (рабочий стол)"
              HorizontalAlignment="Stretch"
              Click="OnFreeClicked" />
      <Button Content="Выбрать приложение..."
              HorizontalAlignment="Stretch"
              Click="OnPickAppClicked" />
    </StackPanel>
  </Border>
</Window>