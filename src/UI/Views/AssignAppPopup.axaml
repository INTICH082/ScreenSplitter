<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ScreenSplitter.UI.Views.AssignAppPopup"
        Width="230" Height="130"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        WindowStartupLocation="Manual">

  <Border Background="{StaticResource BgPanel}"
          CornerRadius="10"
          Padding="14"
          BorderThickness="1"
          BorderBrush="{StaticResource LineHairline}"
          BoxShadow="0 4 14 0 #60000000">
    <StackPanel Spacing="8">
      <TextBlock Text="Что разместить в этой зоне?"
                 Foreground="{StaticResource TextPrimary}"
                 FontSize="12"
                 TextWrapping="Wrap" />
      <Button Content="Свободный доступ (рабочий стол)"
              Classes="action"
              HorizontalAlignment="Stretch"
              Click="OnFreeClicked" />
      <Button Content="Выбрать приложение..."
              Classes="primary"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Click="OnPickAppClicked" />
    </StackPanel>
  </Border>
</Window>