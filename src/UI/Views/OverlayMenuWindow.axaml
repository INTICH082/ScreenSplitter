<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ScreenSplitter.UI.Views.OverlayMenuWindow"
        Width="230" Height="112"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        ShowActivated="False"
        WindowStartupLocation="Manual">

  <Window.Styles>
    <Style Selector="Button.icon-btn">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{StaticResource BgPanelAlt}" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{StaticResource LineHairline}" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AccentSignal}" />
      <Setter Property="TextBlock.Foreground" Value="#0B0E14" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentSignal}" />
    </Style>
  </Window.Styles>

  <Grid>
    <Border x:Name="FullPanel"
            Background="{StaticResource BgPanel}"
            CornerRadius="12"
            Padding="10"
            BorderThickness="1"
            BorderBrush="{StaticResource LineHairline}"
            BoxShadow="0 4 16 0 #60000000">
      <StackPanel Orientation="Vertical" Spacing="8">

        <Grid ColumnDefinitions="*,Auto">
          <Border Grid.Column="0"
                  Background="Transparent"
                  PointerPressed="OnDragHandlePressed"
                  Padding="2">
            <Canvas Width="16" Height="16" HorizontalAlignment="Left">
              <Line StartPoint="8,0" EndPoint="8,4" Stroke="{StaticResource AccentSignal}" StrokeThickness="1.4" />
              <Line StartPoint="8,12" EndPoint="8,16" Stroke="{StaticResource AccentSignal}" StrokeThickness="1.4" />
              <Line StartPoint="0,8" EndPoint="4,8" Stroke="{StaticResource AccentSignal}" StrokeThickness="1.4" />
              <Line StartPoint="12,8" EndPoint="16,8" Stroke="{StaticResource AccentSignal}" StrokeThickness="1.4" />
              <Ellipse Canvas.Left="5.5" Canvas.Top="5.5" Width="5" Height="5" Stroke="{StaticResource AccentSignal}" StrokeThickness="1.2" />
            </Canvas>
          </Border>

          <Button Grid.Column="1"
                  Content="—"
                  Classes="icon-btn"
                  Width="24" Height="24"
                  FontSize="11"
                  Click="OnCollapseClicked"
                  ToolTip.Tip="Свернуть панель" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
          <Button Content="▦" Classes="icon-btn" Click="OnZonesClicked"
                  ToolTip.Tip="Разбить экран на зоны" />
          <Button Content="☰" Classes="icon-btn" Click="OnScenariosClicked"
                  ToolTip.Tip="Сценарии" />
          <Button x:Name="TaskbarButton" Content="⬓" Classes="icon-btn" Click="OnTaskbarToggleClicked"
                  ToolTip.Tip="Скрыть/показать панель задач" />
          <Button Content="⚙" Classes="icon-btn" Click="OnSettingsClicked"
                  ToolTip.Tip="Настройки" />
        </StackPanel>

        <Rectangle Height="1" Fill="{StaticResource LineHairline}" HorizontalAlignment="Stretch" />

        <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center">
          <TextBlock x:Name="CpuLabel" Text="CPU --%" Foreground="{StaticResource TextMuted}"
                     FontFamily="Consolas" FontSize="10" />
          <TextBlock x:Name="GpuLabel" Text="GPU --%" Foreground="{StaticResource TextMuted}"
                     FontFamily="Consolas" FontSize="10" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Свёрнутое состояние: маленькая кнопка раскрытия -->
    <Button x:Name="CollapsedButton"
            Width="38" Height="38"
            CornerRadius="19"
            Background="{StaticResource BgPanel}"
            BorderBrush="{StaticResource AccentSignal}"
            BorderThickness="1.5"
            Padding="0"
            IsVisible="False"
            Click="OnExpandClicked"
            ToolTip.Tip="Открыть панель ScreenSplitter">
      <TextBlock Text="⠿" Foreground="{StaticResource AccentSignal}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Button>
  </Grid>
</Window>