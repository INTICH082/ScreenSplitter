<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ScreenSplitter.UI.Views.SettingsWindow"
        Title="Настройки ScreenSplitter"
        Width="300" Height="140"
        Background="{StaticResource BgPanel}"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

  <StackPanel Margin="20" Spacing="14">
    <TextBlock Text="НАСТРОЙКИ"
               Foreground="{StaticResource TextMuted}"
               FontFamily="Consolas" FontSize="10.5" LetterSpacing="1" />
    <CheckBox x:Name="StartupCheckBox"
              Content="Запускать вместе с Windows"
              Foreground="{StaticResource TextPrimary}"
              IsCheckedChanged="OnStartupCheckedChanged" />
  </StackPanel>
</Window>