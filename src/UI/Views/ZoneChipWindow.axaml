<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ScreenSplitter.UI.Views.ZoneChipWindow"
        Width="168" Height="34"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        ShowActivated="False"
        WindowStartupLocation="Manual">

  <Window.Transitions>
    <Transitions>
      <DoubleTransition Property="Width" Duration="0:0:0.16" Easing="CubicEaseOut" />
      <DoubleTransition Property="Height" Duration="0:0:0.16" Easing="CubicEaseOut" />
    </Transitions>
  </Window.Transitions>

  <Window.Styles>
    <Style Selector="Border#ChipBorder.free">
      <Setter Property="BorderBrush" Value="{StaticResource AccentFree}" />
    </Style>
    <Style Selector="Border#ChipBorder.free Ellipse#StatusDot">
      <Setter Property="Fill" Value="{StaticResource AccentFree}" />
    </Style>

    <Style Selector="Border#ChipBorder.assigned">
      <Setter Property="BorderBrush" Value="{StaticResource AccentAssigned}" />
    </Style>
    <Style Selector="Border#ChipBorder.assigned Ellipse#StatusDot">
      <Setter Property="Fill" Value="{StaticResource AccentAssigned}" />
    </Style>

    <Style Selector="Border#ChipBorder.swap-selected">
      <Setter Property="BorderBrush" Value="{StaticResource AccentSignal}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Компактный вид — когда зона уже занята приложением, чипу больше не нужно бросаться в глаза -->
    <Style Selector="Window.compact">
      <Setter Property="Width" Value="126" />
      <Setter Property="Height" Value="24" />
    </Style>
    <Style Selector="Window.compact Border#ChipBorder">
      <Setter Property="Padding" Value="6,0" />
    </Style>
    <Style Selector="Window.compact TextBlock#Label">
      <Setter Property="FontSize" Value="9.5" />
    </Style>
    <Style Selector="Window.compact Ellipse#StatusDot">
      <Setter Property="Width" Value="5" />
      <Setter Property="Height" Value="5" />
    </Style>
    <Style Selector="Window.compact Image#AppIcon">
      <Setter Property="Width" Value="12" />
      <Setter Property="Height" Value="12" />
    </Style>
    <Style Selector="Window.compact Button#ClearButton">
      <Setter Property="FontSize" Value="8" />
      <Setter Property="Padding" Value="4,1" />
    </Style>
  </Window.Styles>

  <Border x:Name="ChipBorder"
          Background="{StaticResource BgPanel}"
          CornerRadius="17"
          Padding="10,0"
          BorderThickness="1"
          BorderBrush="{StaticResource LineHairline}"
          PointerPressed="OnChipPressed"
          PointerMoved="OnChipPointerMoved"
          PointerReleased="OnChipPointerReleased">
    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
      <Ellipse x:Name="StatusDot"
               Grid.Column="0"
               Width="7" Height="7"
               Fill="{StaticResource TextMuted}"
               Margin="0,0,7,0"
               VerticalAlignment="Center" />
      <Image x:Name="AppIcon"
             Grid.Column="1"
             Width="16" Height="16"
             Margin="0,0,6,0"
             IsVisible="False"
             VerticalAlignment="Center" />
      <TextBlock x:Name="Label"
                 Grid.Column="2"
                 Text="+ Назначить"
                 Foreground="{StaticResource TextPrimary}"
                 FontFamily="Consolas"
                 FontSize="11.5"
                 TextTrimming="CharacterEllipsis"
                 VerticalAlignment="Center" />
      <Button x:Name="ClearButton"
              Grid.Column="3"
              Content="✕"
              Classes="action"
              Padding="6,2"
              FontSize="10"
              Margin="6,0,0,0"
              IsVisible="False"
              Click="OnClearClicked" />
    </Grid>
  </Border>
</Window>